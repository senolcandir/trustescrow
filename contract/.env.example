# Arc Testnet RPC (varsayilan resmi RPC, degistirmene gerek yok)
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Deploy islemini yapacak cuzdanin PRIVATE KEY'i (0x ONSUZ, sadece testnet cuzdani!)
# UYARI: Bu dosyayi asla git'e commit etme, .env dosyasi sadece yerel makinende kalmali.
PRIVATE_KEY=

# Hakem (dispute cozucu) cuzdan adresi. Bos birakilirsa deploy eden adres hakem olur.
ARBITER_ADDRESS=
